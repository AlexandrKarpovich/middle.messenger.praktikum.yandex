{
  "name": "yandex-praktikum-middle.messenger.praktikum.yandex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engine": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "vite build && node server.cjs",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,ts,tsx,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,tsx,css,html,json}\"",
    "remove-empty-lines": "find . -type f -name '*.ts' -exec sed -i '/^$/d' {} + && find . -type f -exec sed -i -e '$a\\' {} +",
    "fix": "npm run format && npm run remove-empty-lines",
    "precommit": "npm run fix"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.1",
    "sass": "^1.84.0",
    "typescript": "~5.7.2",
    "vite": "^6.1.0"
  },
  "dependencies": {
    "express": "^4.21.2",
    "handlebars": "^4.7.8"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit && git add ."
    }
  },
  "lint-staged": {
    "src/**/*.{js,ts,tsx,css,html,json}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ]
  }
}
